datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  ADMIN
}

enum SubscriptionStatus {
  FREE
  PREMIUM
  LIFETIME
}

enum Style {
  PROFESSIONAL
  MODERN
  ACADEMIC
  STARTUP
  MINIMALIST
}

enum ExportFormat {
  PPTX
  PDF
  MARKDOWN
}

model User {
  id                   String             @id @default(auto()) @map("_id") @db.ObjectId
  telegramId           String             @unique
  username             String?
  firstName            String?
  lastName             String?
  role                 Role               @default(USER)
  subscription         SubscriptionStatus @default(FREE)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  isBanned             Boolean            @default(false)
  
  presentations        Presentation[]
  exports              ExportLog[]
}

model Presentation {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  topic       String
  style       Style    @default(PROFESSIONAL)
  audience    String
  language    String   @default("en")
  theme       String   @default("default")
  slideCount  Int      @default(5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  slides      Slide[]
  exports     ExportLog[]
}

model Slide {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  order          Int
  title          String
  content        String
  speakerNotes   String?
  imagePrompt    String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  presentationId String   @db.ObjectId
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExportLog {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  format         ExportFormat
  createdAt      DateTime     @default(now())
  
  userId         String       @db.ObjectId
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  presentationId String       @db.ObjectId
  presentation   Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)
}

model SystemLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  action    String
  details   String?
  createdAt DateTime @default(now())
  
  userId    String?  // Relational link represented as string, clean for MongoDB
}

model SystemSetting {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  key   String @unique
  value String
}
